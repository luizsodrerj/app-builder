{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "clientes-app": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/css/bootstrap-5.0.0-beta1.min.css",
              "src/css/glightbox.min.css",
              "src/css/LineIcons.2.0.css",
              "src/css/tiny-slider.css",
              "src/css/animate.css",
              "src/css/lindy-uikit.css",
              "src/css/styles.css",
              "node_modules/jquery-ui/themes/base/all.css",
              "node_modules/jquery-ui/themes/base/datepicker.css",
              "node_modules/primeicons/primeicons.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.min.js",
              "node_modules/jquery-ui/dist/jquery-ui.min.js",
              "src/js/bootstrap-5.0.0-beta1.min.js",
              "src/js/tiny-slider.js",
              "src/js/wow.min.js",
              "src/js/main.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "clientes-app:build:production"
            },
            "development": {
              "buildTarget": "clientes-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
